xml = r'''<mxfile host="app.diagrams.net">
  <diagram name="Network Diagram">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1200">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="internet" value="PUBLIC INTERNET" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="650" y="20" width="220" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="remote" value="Remote Employees&#10;(AnyConnect VPN)" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="120" width="180" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="cust" value="External Customers&#10;(HTTPS 443 Only)" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="650" y="120" width="180" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="m365" value="M365 / Cloud Services&#10;(SharePoint / Exchange)" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="1150" y="120" width="220" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="router" value="Edge Border Router&#10;Cisco 7600" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="640" y="250" width="240" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="fw" value="HA Fortinet 800D NGFW Cluster" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="600" y="370" width="320" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="core" value="Zone 1: Core Switching &amp; Routing Infrastructure&#10;Stacked Cisco Switches" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="520" y="520" width="280" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="dmz" value="Zone 2: DMZ&#10;Nginx Proxies&#10;FTP Server (Ubuntu)" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="150" y="500" width="250" height="110" as="geometry"/>
        </mxCell>

        <mxCell id="cloud" value="Zone 5: AWS / Azure VPC Hybrid Cloud&#10;Azure AD / Entra ID&#10;Cloud Storage" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="1020" y="500" width="300" height="110" as="geometry"/>
        </mxCell>

        <mxCell id="lan" value="Zone 3: Corporate LANs&#10;VLAN 10 Corp&#10;Printers VLAN 8" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="250" y="700" width="220" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="servers" value="Zone 4: Servers VLAN&#10;AD DCs&#10;App &amp; File Servers" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="580" y="700" width="220" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="wifi" value="Zone 6: Meraki WAPs&#10;802.1X / WPA3&#10;Guest Wi‑Fi Isolated" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="910" y="700" width="220" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="vpn" value="Secure Site-to-Site VPN" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="1100" y="680" width="220" height="60" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>'''

path = "/mnt/data/network_architecture.drawio"
Path(path).write_text(xml, encoding="utf-8")

print(path)
